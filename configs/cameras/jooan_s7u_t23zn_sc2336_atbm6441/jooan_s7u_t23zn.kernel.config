# Kernel config for T23ZN with ATBM6441
#
# Most config (MMC1, wireless stack, CONFIG_BUG, DYNAMIC_DEBUG) is set via
# WIFI_ATBM6441_LINUX_CONFIG_FIXUPS in package/wifi-atbm6441/wifi-atbm6441.mk
# to avoid being dropped by olddefconfig.
#
# Place any board-specific kernel options here that are NOT MMC/wireless related.

# FAT32 SD cards (exFAT comes from the exfat-nofuse module via BR2_THINGINO_SDCARD)
CONFIG_VFAT_FS=y
CONFIG_FAT_DEFAULT_CODEPAGE=437
CONFIG_FAT_DEFAULT_IOCHARSET="iso8859-1"
CONFIG_NLS_ISO8859_1=y

# UART0 (T23 PB19 TXD / PB22 RXD, non-flow-control) -> /dev/ttyS0.
# Wired to the ATBM6441 MCU UART = the vendor's PIR/MCU control channel.
# Pin muxing comes from patch 0093 (defaults platform_devio_array to
# UART0_PORTB); the FC variant is avoided as PB20/PB21 are PTZ tilt GPIOs.
CONFIG_SERIAL_JZ47XX_UART0=y
